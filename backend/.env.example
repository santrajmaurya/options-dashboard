APP_NAME=Nifty Option Selling Dashboard API
APP_ENV=development
DEBUG=true

HOST=0.0.0.0
PORT=8000

FRONTEND_URL=http://localhost:5173

# ==========================================
# MARKET DATA PROVIDER
# Supported values: mock, upstox
# ==========================================
MARKET_DATA_PROVIDER=mock

# ==========================================
# UPSTOX
# ==========================================
UPSTOX_ACCESS_TOKEN=
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=http://localhost:8000/api/auth/upstox/callback

UPSTOX_API_BASE_URL=https://api.upstox.com

# ==========================================
# UPSTOX INSTRUMENT KEYS
# ==========================================
UPSTOX_NIFTY_INSTRUMENT_KEY=NSE_INDEX|Nifty 50
UPSTOX_VIX_INSTRUMENT_KEY=NSE_INDEX|India VIX
UPSTOX_NIFTY_FUTURES_INSTRUMENT_KEY=
UPSTOX_BREADTH_INSTRUMENT_KEYS=
IV_HISTORY_FILE=iv_history.json